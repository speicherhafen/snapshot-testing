{
    "name": "kigaroo/snapshot-testing",
    "description": "Provides PHPUnit assertions for snapshot testing",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false
        }
    },
    "autoload": {
        "psr-4": {
            "KigaRoo\\SnapshotTesting\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": { "Tests\\": ["tests/unit"] }
    },
    "require": {
        "php": "^8.1",
        "ext-dom": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-simplexml": "*",
        "symfony/property-access": "^5.4 || ^6.4 || ^7.0",
        "webmozart/assert": "^1.11"
    },
    "require-dev": {
        "doctrine/coding-standard": "^12.0",
        "phpunit/phpunit": "^10.5 || ^11.0"
    }
}
